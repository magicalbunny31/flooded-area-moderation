{
   "name": "@flufflestack/flooded-area-moderation",
   "version": "3.3.0",
   "main": "./src/index.js",
   "type": "module",
   "scripts": {
      "start": "node --experimental-sqlite ./src/index.js",
      "dev": "docker compose up --build --watch",
      "lint": "eslint .",
      "docker:up": "docker compose up --build",
      "docker:down": "docker compose down --remove-orphans --rmi all --volumes",
      "dotenvx:precommit": "dotenvx ext precommit",
      "dotenvx:encrypt": "dotenvx encrypt -f ./src/.env -fk ./src/.env.keys",
      "dotenvx:decrypt": "dotenvx decrypt -f ./src/.env -fk ./src/.env.keys"
   },
   "repository": {
      "type": "git",
      "url": "git+https://github.com/magicalbunny31/flooded-area-moderation.git"
   },
   "contributors": [
      {
         "name": "magicalbunny31",
         "email": "hewwo@nuzzles.dev",
         "url": "https://nuzzles.dev/"
      }
   ],
   "bugs": {
      "url": "https://github.com/magicalbunny31/flooded-area-moderation/issues"
   },
   "engines": {
      "node": ">=24",
      "pnpm": ">=10.33"
   },
   "homepage": "https://flufflestack.nuzzles.dev/flooded-area-moderation",
   "dependencies": {
      "@dotenvx/dotenvx": "^1.61.0",
      "@google-cloud/firestore": "8.3.0",
      "@magicalbunny31/fennec-utilities": "github:magicalbunny31/fennec-utilities",
      "@magicalbunny31/pawesome-utility-stuffs": "github:magicalbunny31/pawesome-utility-stuffs#feature/v3",
      "better-logging": "^5.0.0",
      "chalk": "^5.6.2",
      "dayjs": "^1.11.20",
      "discord.js": "^14.26.3",
      "node-cache": "^5.1.2",
      "set-interval-async": "^3.0.3"
   },
   "devDependencies": {
      "eslint": "^10.2.0",
      "globals": "^17.5.0"
   }
}
